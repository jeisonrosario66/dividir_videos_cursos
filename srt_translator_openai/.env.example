# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Rutas
INPUT_DIR=/absolute/path/to/source_srt
OUTPUT_DIR=/absolute/path/to/es_srt
WORK_DIR=

# batch o sync
TRANSLATION_MODE=sync

# Optimizacion
OVERWRITE=false
SYNC_CONCURRENCY=4
CHUNK_MAX_CHARS=4500
MAX_SEGMENTS_PER_CHUNK=80
MAX_GLOSSARY_LINES_PER_CHUNK=60

# Contexto BJJ
TARGET_LANGUAGE=es
GLOSSARY_PATH=/app/glossary_bjj.txt
COURSE_CONTEXT=BJJ instructional subtitles. Preserve technique names and translate naturally to Latin American Spanish.

# Batch helpers
BATCH_REQUESTS_PATH=
BATCH_RESULTS_PATH=
BATCH_MANIFEST_PATH=
BATCH_ID=
