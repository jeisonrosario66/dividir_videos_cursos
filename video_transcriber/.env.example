# Ruta con los videos de prueba o videos reales
INPUT_DIR=/absolute/path/to/videos

# Si lo dejas vacio, el runner usa ../subtitulos respecto a INPUT_DIR
OUTPUT_DIR=

# local para CPU modesta, vast para GPU
PROFILE=local

# tiny/base para PC con 4 GB, large-v3 para Vast.ai
MODEL=tiny

# Usa auto si quieres deteccion automatica
LANGUAGE=es

# false o true
OVERWRITE=false

# Cantidad de archivos en paralelo. En local usa 1.
# En GPU de 24 GB normalmente puedes probar con 2.
PARALLEL_FILES=1
